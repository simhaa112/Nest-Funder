<% layout("/layouts/boilerPlates.ejs") %>

<body>
  <style>
    .search-bar { width: 100%; display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-bottom: 1.5rem; }
    .search-input { min-width: 220px; max-width: 420px; }
    #filters { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; }
    .filter { text-align: center; margin-right: 2rem; margin-top: 1.5rem; opacity: 0.7; transition: opacity 0.3s ease; }
    .filter:hover { opacity: 1; cursor: pointer; }
    .filter p { font-size: 0.9rem; margin-top: 0.5rem; }
    .tax-info { display: none; }
    .tax-toggle { border: 2px solid black; border-radius: 1rem; padding: 1rem; height: 3.25rem; margin-left: 3rem; display: flex; align-items: center; opacity: 0.8; transition: opacity 0.3s ease; }
    .tax-toggle:hover { opacity: 1; }
    .tax-toggle .form-check-label { margin-left: 10px; }
    .card-img-top { object-fit: cover; }
    .listing-link { text-decoration: none; color: inherit; }
    .card { margin-bottom: 2rem; }
    @media (max-width: 767px) { .tax-toggle { margin-left: 0; margin-top: 1rem; width: 100%; justify-content: center; } }
    .card-body { background-color: #fff; padding: 1rem; }
    .card-img-top { height: 100%; object-fit: cover; border-radius: 0.5rem; transition: transform 0.3s ease-in-out; }
    .zoom-image { transition: transform 0.5s ease; }
    .zoom-image:hover { transform: scale(1.1); }
    .tax-info { display: inline-block; font-size: 0.85rem; }
    @media (max-width: 576px) { .card-body p { font-size: 0.9rem; } }
    .card-text { padding-left: 12px; padding-top: 12px; }
  </style>

  <form class="search-bar" action="/listings" method="GET" autocomplete="off">
    <div class="position-relative" style="width: 100%; max-width: 420px;">
      <input
        id="searchInput"
        class="form-control search-input"
        type="search"
        name="q"
        placeholder="AI Search listings, locations, categories..."
        value="<%= searchQuery || '' %>"
      />
      <div id="suggestionsBox" class="list-group position-absolute w-100 shadow-sm" style="z-index: 20; display: none;"></div>
    </div>
    <input type="hidden" name="category" id="searchCategory" value="<%= selectedCategory || 'All' %>" />
    <button class="btn btn-primary" type="submit">AI Search</button>
    <% if (searchQuery) { %>
      <a class="btn btn-outline-secondary" href="/listings">Clear</a>
    <% } %>
  </form>

  <% if (searchQuery) { %>
    <div class="text-center mb-3">
      Showing results for "<%= searchQuery %>"
      <% if (selectedCategory && selectedCategory !== 'All') { %>
        in "<%= selectedCategory %>"
      <% } %>
    </div>
  <% } %>

  <div id="filters">
    <div class="filter" onclick="filterListings('Trending')"><i class="fa-solid fa-fire"></i><p>Trending</p></div>
    <div class="filter" onclick="filterListings('Room')"><i class="fa-solid fa-bed"></i><p>Room</p></div>
    <div class="filter" onclick="filterListings('Iconic Cities')"><i class="fa-solid fa-mountain-city"></i><p>Iconic Cities</p></div>
    <div class="filter" onclick="filterListings('Hostels')"><i class="fa-solid fa-hotel"></i><p>Hostels</p></div>
    <div class="filter" onclick="filterListings('Guest House')"><i class="fa-solid fa-house-user"></i><p>Guest House</p></div>
    <div class="filter" onclick="filterListings('Swimming Pools')"><i class="fa-solid fa-person-swimming"></i><p>Swimming Pools</p></div>
    <div class="filter" onclick="filterListings('Shops')"><i class="fa-solid fa-shop"></i><p>Shops</p></div>
    <div class="filter" onclick="filterListings('Camping')"><i class="fa-solid fa-campground"></i><p>Camping</p></div>

    <div class="tax-toggle">
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
        <label class="form-check-label" for="flexSwitchCheckDefault">Add Taxes</label>
      </div>
    </div>
  </div>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 rounded-3">
    <% if (allListings.length === 0) { %>
      <div style="width: 100%; height: 60vh; display: flex; justify-content: center; align-items: center; text-align: center; font-size: 1.5rem; color: #555;">
        <h2>No listings found!</h2>
      </div>
    <% } else { %>
      <% for (let listing of allListings) { %>
        <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none">
          <div class="card h-100 shadow-sm border-0 rounded-3 mb-4">
            <div class="card-img-top overflow-hidden rounded-3" style="height: 20rem;">
              <img src="<%= listing.image?.url || '/images/fallback.jpg' %>" class="card-img-top rounded-3 zoom-image" alt="listing_image">
            </div>
            <div class="card-body p-6">
              <p class="card-text">
                <b><%= listing.title %></b> <br>
                &#8377; <%= listing.price.toLocaleString("en-IN") %>/night
                <i class="tax-info text-muted">&nbsp; &nbsp; + 18% GST</i>
              </p>
            </div>
          </div>
        </a>
      <% } %>
    <% } %>
  </div>

  <script>
    // Tax toggle
    let taxSwitch = document.getElementById("flexSwitchCheckDefault");
    taxSwitch.addEventListener("click", () => {
      let taxInfo = document.getElementsByClassName("tax-info");
      for (let info of taxInfo) {
        info.style.display = (info.style.display != "inline") ? "inline" : "none";
      }
    });

    // Category filter
    function filterListings(category) {
      const urlParams = new URLSearchParams(window.location.search);
      urlParams.set("category", category); // add/update category
      window.location.href = `/listings?${urlParams.toString()}`;
    }

    // Autocomplete suggestions
    const searchInput = document.getElementById("searchInput");
    const suggestionsBox = document.getElementById("suggestionsBox");
    const categoryInput = document.getElementById("searchCategory");
    let debounceTimer;

    searchInput.addEventListener("input", () => {
      const query = searchInput.value.trim();
      clearTimeout(debounceTimer);
      if (!query) {
        suggestionsBox.style.display = "none";
        return;
      }

      debounceTimer = setTimeout(async () => {
        try {
          const category = categoryInput.value || "All";
          const response = await fetch(`/listings/suggestions?q=${encodeURIComponent(query)}&category=${encodeURIComponent(category)}`);
          const suggestions = await response.json();
          renderSuggestions(suggestions);
        } catch (error) {
          suggestionsBox.style.display = "none";
        }
      }, 250);
    });

    function renderSuggestions(items) {
      if (!items.length) {
        suggestionsBox.style.display = "none";
        return;
      }
      suggestionsBox.innerHTML = items
        .map(item => {
          const label = `${item.title} • ${item.location} • ${item.category}`;
          return `<button type="button" class="list-group-item list-group-item-action suggestion-item">${label}</button>`;
        })
        .join("");
      suggestionsBox.style.display = "block";
      document.querySelectorAll(".suggestion-item").forEach((button, index) => {
        button.addEventListener("click", () => {
          const selected = items[index];
          searchInput.value = selected.title;
          suggestionsBox.style.display = "none";
          searchInput.focus();
        });
      });
    }

    document.addEventListener("click", (event) => {
      if (!event.target.closest("#searchInput") && !event.target.closest("#suggestionsBox")) {
        suggestionsBox.style.display = "none";
      }
    });
  </script>
</body>
